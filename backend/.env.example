# Server Configuration
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Database
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxx.mongodb.net/campus-resell?retryWrites=true&w=majority

# JWT Settings
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# Cloudinary Credentials (For image uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Email Configuration (SMTP for Verification)
# For development, email tokens are logged to the console if SMTP is not active
EMAIL_HOST=smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_USER=your_smtp_username
EMAIL_PASS=your_smtp_password
EMAIL_FROM=noreply@campusresell.edu

# Domain Restriction (College emails only)
# Set to 'edu' to match any .edu email, or 'mycollege.edu' for a specific campus
COLLEGE_DOMAIN=anurag.edu.in
